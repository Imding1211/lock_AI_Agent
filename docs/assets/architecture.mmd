---
config:
  theme: base
  themeVariables:
    primaryColor: '#4A90D9'
    primaryTextColor: '#000'
    primaryBorderColor: '#2E6CB5'
    lineColor: '#333333'
    secondaryColor: '#E8F5E9'
    tertiaryColor: '#FFF3E0'
  layout: elk
---
graph TD
    LINE_USER(("LINE 使用者"))

    subgraph debounce_layer ["防抖層（app.py + core/debounce.py + core/line_bot.py）"]
        direction TB
        webhook["webhook<br/><small>接收 LINE 訊息<br/>顯示 Loading 動畫<br/>記錄 user_raw 審計日誌</small>"]
        buffer["訊息緩衝池<br/><small>累積多則訊息<br/>新訊息重設計時器<br/>buffer_wait 秒後送出</small>"]
        langgraph_reply["langgraph_and_reply<br/><small>記錄 user + ai 審計日誌<br/>傳遞 response_ui</small>"]
        webhook --> buffer
        buffer --> langgraph_reply
    end

    subgraph supervisor_graph ["Supervisor Graph（LangGraph + PostgreSQL Checkpointer）"]
        pre_process["pre_process<br/><small>載入 user profile<br/>注入 [前情提要] 摘要<br/>加入 HumanMessage<br/>組裝 messages</small>"]
        manage_memory["manage_memory<br/><small>語意摘要壓縮<br/>messages > 閾值時觸發<br/>LLM 壓縮舊訊息</small>"]
        router["router<br/><small>敏感詞攔截 → 強制轉接<br/>LLM 意圖分類<br/>直產轉接表單/拒絕語<br/>→ next_agents</small>"]
        merge_answers["merge_answers<br/><small>提取 answer<br/>多 agent 時 LLM 合併<br/>話題偵測<br/>轉接後清除 agent 訊息</small>"]
        update_profile["update_profile<br/><small>LLM 萃取個資<br/>更新 user profile</small>"]
        post_process["post_process<br/><small>Markdown 清洗<br/>UI 工廠（ui_hints → FlexMessage）<br/>回傳 answer + response_ui</small>"]
    end

    subgraph agents_layer ["Agent 子圖（Send fan-out 平行派發 + ui_hints 攔截）"]
        subgraph hardware_technician_sub ["hardware_technician"]
            direction LR
            HT_LLM["agent_llm"]
            HT_TOOL["tool_node"]
            HT_LLM -->|tool_calls| HT_TOOL
            HT_TOOL -->|tool results| HT_LLM
        end

        subgraph sales_representative_sub ["sales_representative"]
            direction LR
            SR_LLM["agent_llm"]
            SR_TOOL["tool_node"]
            SR_LLM -->|tool_calls| SR_TOOL
            SR_TOOL -->|tool results| SR_LLM
        end

        subgraph store_assistant_sub ["store_assistant"]
            direction LR
            SA_LLM["agent_llm"]
            SA_TOOL["tool_node"]
            SA_LLM -->|tool_calls| SA_TOOL
            SA_TOOL -->|tool results| SA_LLM
        end

        subgraph app_specialist_sub ["app_specialist"]
            direction LR
            AS_LLM["agent_llm"]
            AS_TOOL["tool_node<br/><small>攔截 UI metadata<br/>→ ui_hints (VIDEO_CARD)</small>"]
            AS_LLM -->|tool_calls| AS_TOOL
            AS_TOOL -->|tool results| AS_LLM
        end

        subgraph manual_librarian_sub ["manual_librarian"]
            direction LR
            ML_LLM["agent_llm"]
            ML_TOOL["tool_node<br/><small>攔截 UI metadata<br/>→ ui_hints (DOWNLOAD_CARD)</small>"]
            ML_LLM -->|tool_calls| ML_TOOL
            ML_TOOL -->|tool results| ML_LLM
        end

        subgraph web_researcher_sub ["web_researcher"]
            direction LR
            WR_LLM["agent_llm"]
            WR_TOOL["tool_node"]
            WR_LLM -->|tool_calls| WR_TOOL
            WR_TOOL -->|tool results| WR_LLM
        end

        subgraph receptionist_sub ["receptionist（tool-less）"]
            RC_LLM["agent_llm<br/><small>無工具，直接回覆</small>"]
        end
    end

    subgraph prompts_store ["System Prompts"]
        direction LR
        prompt_router[("router.md<br/><small>意圖分類器</small>")]
        prompt_ht[("hardware_technician.md<br/><small>硬體維修技師</small>")]
        prompt_sr[("sales_representative.md<br/><small>報價與客服專員</small>")]
        prompt_sa[("store_assistant.md<br/><small>門市與規格助理</small>")]
        prompt_as[("app_specialist.md<br/><small>APP 設定專家</small>")]
        prompt_ml[("manual_librarian.md<br/><small>說明書管理員</small>")]
        prompt_wr[("web_researcher.md<br/><small>網路搜尋助手</small>")]
        prompt_rc[("receptionist.md<br/><small>前台接待專員</small>")]
        prompt_merge[("merge_answers.md<br/><small>多回覆合併</small>")]
        prompt_profile[("update_profile.md<br/><small>輪廓更新</small>")]
        prompt_summarize[("summarize_messages.md<br/><small>語意摘要壓縮</small>")]
        prompt_transfer[("transfer_human_form.md<br/><small>轉接真人表單</small>")]
    end

    subgraph tools_store ["Tools（UI_TYPE_MAP 驅動 ui_type）"]
        direction LR
        tool_video[("db_video<br/><small>核心技術與維修知識庫</small>")]
        tool_line_chat[("db_line_chat<br/><small>客服實務與報價知識庫</small>")]
        tool_website[("db_website<br/><small>營業資訊與產品規格知識庫</small>")]
        tool_youtube[("db_youtube<br/><small>APP 操作教學影片知識庫<br/>ui_type=VIDEO_CARD</small>")]
        tool_manuals[("db_manuals<br/><small>說明書 PDF 下載連結<br/>ui_type=DOWNLOAD_CARD</small>")]
        tool_order[("db_order_api<br/><small>查詢即時訂單狀態與報修進度</small>")]
        tool_web[("db_web_search<br/><small>網際網路搜尋引擎</small>")]
        tool_transfer[("transfer_to_human<br/><small>轉接真人客服</small>")]
    end

    subgraph data_stores ["外部資料源"]
        direction LR
        pgvec_video[("pgvector<br/><small>kb_video</small>")]
        pgvec_line_chat[("pgvector<br/><small>kb_line_chat</small>")]
        pgvec_website[("pgvector<br/><small>kb_website</small>")]
        pgvec_youtube[("pgvector<br/><small>kb_youtube</small>")]
        pgvec_gdrive[("pgvector<br/><small>kb_gdrive</small>")]
        order_api[("Order API<br/><small>訂單 / 維修單</small>")]
        duckduckgo[("DuckDuckGo<br/><small>網頁搜尋</small>")]
    end

    subgraph persistence ["持久化儲存"]
        direction LR
        profile_store[("User Profiles<br/><small>./data/profiles/*.md</small>")]
        pg_checkpointer[("PostgreSQL<br/><small>Checkpointer + 對話記憶</small>")]
        pg_audit[("PostgreSQL<br/><small>audit_log 表<br/>審計日誌</small>")]
        pg_facts[("PostgreSQL<br/><small>user_facts 表<br/>SCD Type 2</small>")]
    end

    subgraph ai_engines ["AI 引擎（工廠模式動態載入）"]
        direction LR
        LLM_ENGINE["LLM Engine<br/><small>Gemini / Vertex AI / Ollama<br/>config.toml [llm]</small>"]
        EMBEDDING_ENGINE["Embedding Engine<br/><small>Vertex AI / Ollama<br/>各 [[databases]] 獨立設定</small>"]
    end
    LINE_USER -->|"傳送訊息"| webhook
    langgraph_reply -->|"合併訊息"| pre_process
    pre_process --> manage_memory
    manage_memory --> router
    router -->|"hardware_tech"| hardware_technician_sub
    router -->|"sales_and_service"| sales_representative_sub
    router -->|"store_info"| store_assistant_sub
    router -->|"app_support"| app_specialist_sub
    router -->|"manual_request"| manual_librarian_sub
    router -->|"web_search"| web_researcher_sub
    router -->|"general_reception"| receptionist_sub
    router -->|"out_of_domain / transfer_human<br/><small>Router 直接產生 answer</small>"| merge_answers
    hardware_technician_sub --> merge_answers
    sales_representative_sub --> merge_answers
    store_assistant_sub --> merge_answers
    app_specialist_sub --> merge_answers
    manual_librarian_sub --> merge_answers
    web_researcher_sub --> merge_answers
    receptionist_sub --> merge_answers
    merge_answers --> update_profile
    update_profile --> post_process
    post_process -->|"answer + response_ui"| langgraph_reply
    langgraph_reply -->|"Reply / Push API<br/><small>TextMessage + FlexMessage</small>"| LINE_USER
    prompt_transfer --- router
    prompt_summarize --- manage_memory
    prompt_router --- router
    prompt_ht --- HT_LLM
    prompt_sr --- SR_LLM
    prompt_sa --- SA_LLM
    prompt_as --- AS_LLM
    prompt_ml --- ML_LLM
    prompt_wr --- WR_LLM
    prompt_rc --- RC_LLM
    prompt_merge --- merge_answers
    prompt_profile --- update_profile
    tool_transfer --- router
    tool_video --- HT_TOOL
    tool_transfer --- HT_TOOL
    tool_line_chat --- SR_TOOL
    tool_transfer --- SR_TOOL
    tool_website --- SA_TOOL
    tool_transfer --- SA_TOOL
    tool_youtube --- AS_TOOL
    tool_transfer --- AS_TOOL
    tool_manuals --- ML_TOOL
    tool_transfer --- ML_TOOL
    tool_web --- WR_TOOL
    tool_transfer --- WR_TOOL
    tool_video --- pgvec_video
    tool_line_chat --- pgvec_line_chat
    tool_website --- pgvec_website
    tool_youtube --- pgvec_youtube
    tool_manuals --- pgvec_gdrive
    tool_order --- order_api
    tool_web --- duckduckgo
    pre_process -.->|"載入"| profile_store
    pre_process -.->|"載入事實"| pg_facts
    update_profile -.->|"儲存"| profile_store
    update_profile -.->|"寫入事實"| pg_facts
    manage_memory -.->|"讀寫摘要"| pg_checkpointer
    webhook -.->|"user_raw"| pg_audit
    langgraph_reply -.->|"user + ai"| pg_audit
    EMBEDDING_ENGINE -..- pgvec_video
    EMBEDDING_ENGINE -..- pgvec_line_chat
    EMBEDDING_ENGINE -..- pgvec_website
    EMBEDDING_ENGINE -..- pgvec_youtube
    EMBEDDING_ENGINE -..- pgvec_gdrive
    LLM_ENGINE -..- manage_memory
    LLM_ENGINE -..- router
    LLM_ENGINE -..- HT_LLM
    LLM_ENGINE -..- SR_LLM
    LLM_ENGINE -..- SA_LLM
    LLM_ENGINE -..- AS_LLM
    LLM_ENGINE -..- ML_LLM
    LLM_ENGINE -..- WR_LLM
    LLM_ENGINE -..- RC_LLM
    LLM_ENGINE -..- merge_answers
    LLM_ENGINE -..- update_profile
    classDef userNode fill:#A5D6A7,stroke:#388E3C,color:#000,stroke-width:2px
    classDef debounce fill:#FFE0B2,stroke:#F57C00,color:#000,stroke-width:1px
    classDef process fill:#BBDEFB,stroke:#1976D2,color:#000,stroke-width:1px
    classDef router_style fill:#FFCC80,stroke:#EF6C00,color:#000,stroke-width:2px
    classDef special fill:#FFCDD2,stroke:#D32F2F,color:#000,stroke-width:1px
    classDef agent_llm fill:#C8E6C9,stroke:#43A047,color:#000,stroke-width:1px
    classDef agent_tool fill:#B2DFDB,stroke:#00897B,color:#000,stroke-width:1px
    classDef datastore fill:#D7CCC8,stroke:#5D4037,color:#000,stroke-width:1px
    classDef persist fill:#CFD8DC,stroke:#455A64,color:#000,stroke-width:1px
    classDef llm_style fill:#90CAF9,stroke:#1565C0,color:#000,stroke-width:2px
    classDef prompt_style fill:#E1BEE7,stroke:#7B1FA2,color:#000,stroke-width:1px
    classDef tool_style fill:#B2EBF2,stroke:#0097A7,color:#000,stroke-width:1px

    class LINE_USER userNode
    class webhook,buffer debounce
    class pre_process,manage_memory,merge_answers,update_profile,post_process process
    class router router_style
    class HT_LLM,SR_LLM,SA_LLM,AS_LLM,ML_LLM,WR_LLM,RC_LLM agent_llm
    class HT_TOOL,SR_TOOL,SA_TOOL,AS_TOOL,ML_TOOL,WR_TOOL agent_tool
    class pgvec_video,pgvec_line_chat,pgvec_website,pgvec_youtube,pgvec_gdrive,order_api,duckduckgo datastore
    class profile_store,pg_checkpointer,pg_audit,pg_facts persist
    class LLM_ENGINE,EMBEDDING_ENGINE llm_style
    class prompt_router,prompt_ht,prompt_sr,prompt_sa,prompt_as,prompt_ml,prompt_wr,prompt_rc,prompt_merge,prompt_profile,prompt_summarize,prompt_transfer prompt_style
    class langgraph_reply debounce
    class tool_video,tool_line_chat,tool_website,tool_youtube,tool_manuals,tool_order,tool_web,tool_transfer tool_style
